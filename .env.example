PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/searchengine?appName=Cluster0

# Elasticsearch (local)
ELASTICSEARCH_URL=http://localhost:9200
# Elasticsearch (Elastic Cloud — set this in production)
ELASTICSEARCH_API_KEY=

# Redis (local)
REDIS_URL=redis://localhost:6379
